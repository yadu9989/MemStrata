# Environment — never commit live secrets
.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
# V5.2-D — python.org-based Nuitka build env (see dist/BUILD_NOTES.md).
build_env/

# Testing
.pytest_cache/
.coverage
htmlcov/

# Editor
.vscode/
.idea/
*.swp

# Node / JS package managers
node_modules/

# Generated build artifacts (TS → JS). The source-of-truth is the
# corresponding *.ts files in extension/src/ and browser-extension/src/.
extension/out/
*.tsbuildinfo

# Compiled / packaged extension bundles. Rebuilt by `npm run package`.
*.vsix

# Strategy drafts maintained in MS Word; kept on disk for reference, not
# in git history.
*.docx

# Local-only sandbox state — Claude Code scheduler, ad-hoc SQLite DBs,
# Nuitka crash dumps from failed builds.
.claude/
nuitka-crash-report.xml
memory_layer.db
